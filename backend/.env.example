# Serveur
PORT=3001

# MongoDB
MONGODB_URI=

# GitHub (optionnel — sans token : 60 req/h, avec token : 5000 req/h)
GITHUB_TOKEN=

# Subreddits à surveiller (séparés par des virgules)
REDDIT_SUBREDDITS=programming,webdev,MachineLearning,devops,javascript

# Cookie de session Reddit : Le cookie `loid` suffit. A copier depuis le navigateur
REDDIT_COOKIE=loid=...

# Topics GitHub à surveiller (séparés par des virgules)
GITHUB_TOPICS=web,ai,devops,cli,database
